generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  name        String
  phone       String
  role        String
  institution String?
  batch_year  Int?
  otp         String?
  otpExpire   DateTime?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Profile extensions
  bio         String?
  company     String?
  position    String?
  location    String?
  industry    String?
  skills      String[] // Array of skills
  profileViews Int     @default(0)

  // Relations
  posts       Post[]
  comments    Comment[]
  jobs        Job[]
  notifications Notification[]
  
  // Connections where user is the requester
  sentConnections Connection[] @relation("Requester")
  // Connections where user is the recipient
  receivedConnections Connection[] @relation("Recipient")
}

model Post {
  id        Int       @id @default(autoincrement())
  content   String
  image     String?
  video     String?
  createdAt DateTime  @default(now())
  likes     Int       @default(0) // We will use a simple counter for now
  
  authorId  Int
  author    User      @relation(fields: [authorId], references: [id])
  comments  Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
}

model Job {
  id          Int      @id @default(autoincrement())
  title       String
  company     String
  location    String
  type        String
  experience  String
  salary      String?
  description String
  requirements String[]
  benefits    String[]
  remote      Boolean  @default(false)
  urgent      Boolean  @default(false)
  createdAt   DateTime @default(now())
  applicants  Int      @default(0)

  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])
}

model Connection {
  id          Int      @id @default(autoincrement())
  status      String   @default("pending") // "pending", "accepted", "rejected"
  createdAt   DateTime @default(now())

  requesterId Int
  requester   User     @relation("Requester", fields: [requesterId], references: [id])
  
  recipientId Int
  recipient   User     @relation("Recipient", fields: [recipientId], references: [id])

  @@unique([requesterId, recipientId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  location    String?
  color       String   @default("bg-blue-500")
  createdAt   DateTime @default(now())
}
